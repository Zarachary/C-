//添加部分
void AddContact() //添加联系人
{   
    int choiceAC;

    if (count >= MAX)
    {
        printf("通讯录已满！无法添加联系人，请删除失联的联系人或联系员扩容！\n");
        printf("是否去删除联系人（Y/N）:");
        getchar();
        scanf("%c",&choiceAC);
        while(choiceAC == 'y' || choiceAC == 'Y')
        {
            DeletContacts();
        }
        return;
    }
    
    printf("请输入姓名：");
    scanf("%s",contacts[count].name);

    printf("请输入性别：");
    scanf("%s",contacts[count].gender);

    printf("请输入电话号码：");
    scanf("%s",contacts[count].phone);

    count++;
    printf("添加成功！当前共有 %d 人\n",count);
    
}


