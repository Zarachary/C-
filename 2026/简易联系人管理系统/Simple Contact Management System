void FilterByName()//按姓名筛选
{
    char name[NAME_LEN];
    printf("请输入想要筛选的名字；");
    scanf("%s",name);

    int filterbyname = 0;

    printf("=====筛选结果====\n");
    printf("姓名\t性别\t电话号码\n");
    printf("-------------------------------\n");

    for (int i = 0; i < count; i++)
    {
        if (strcmp(contacts[i].name,name) == 0)
        {
            printf("%s\t%s\t%s\n",contacts[i].name,contacts[i].gender,contacts[i].phone);

            filterbyname++;
        }
        
    }
    if (filterbyname == 0)
    {
        printf("未找到姓名为 '%s' 的联系人\n",name);
    }
    else
    {
        printf("共找到 '%d'人\n",filterbyname);
    }
    
}

