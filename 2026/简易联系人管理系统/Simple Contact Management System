//删除部分
void DeletContacts()//删除联系人（总）
{
    char choiceDC;

     if (count == 0 )
    {
        printf("通讯录为空！！！\n");
        printf("是否添加联系人Y/N:");
        getchar();
        scanf("%c",&choiceDC);
    
    while(choiceDC == 'y' || choiceDC == 'Y')
    {
        AddContact();
    }

    return;

    }

    int DeletNamOrPhone;
    //选择按名字删除，按号码删除

    do
    {
        printf("选择你的删除方式：\n");
        printf("1.通过输入姓名删除：\n");
        printf("2.通过输入号码删除：\n");
        scanf("%d",&DeletNamOrPhone);
        switch (DeletNamOrPhone)
        {
        case 1 : DeletContactsByName();
            break;
        case 2 : DeletContactsByPhone();
            break;
        default:
            printf("输入无效，请重新输入\n");
            break;
        }

    } while (DeletNamOrPhone !=1 && DeletNamOrPhone != 2);
    
    return;
}

void DeletContactsByName()//按姓名删除
{
    char name[NAME_LEN];
    printf("请输入想要删除联系人的姓名：");
    scanf("%s",name);

    int index = -1;

    for (int i = 0; i < count; i++)
    {
        if (strcmp(contacts[i].name,name) == 0)
        {
            index = i;
            break;
        }
    }
        if (index == -1)
        {
            printf("未找到姓名为'%s'的联系人！\n",name);
            return;
        }
    for (int i = index; i < count - 1; i++)
    {
        contacts[i]=contacts[i+1];
    }
    count--;
    printf("联系人 '%s' 已经删除！现共有 %d 人\n",name ,count);    
}

void DeletContactsByPhone()//按号码删除
{
    char phone[PHONE_LEN];
    printf("请输入你想删除的号码：");
    scanf("%s",phone);

     int index = -1;

    for (int i = 0; i < count; i++)
    {
         if (strcmp(contacts[i].phone,phone) == 0)
         {
            index = i;
            break;
         }
    }
        if (index == -1)
        {
            printf("未找到号码为 “%s” 的联系人！\n",phone);
            return;
        }
    for (int i = index; i < count - 1; i++)
    {
        contacts[i]=contacts[i+1];
    }
    count--;
    printf("联系人 '%s' 已经删除！现共有 %d 人\n",phone,count);
}



//载入部分
void LoadContacts()
{
    FILE *fp =fopen("contacts.txt","r");
    if (fp == NULL)
    {
        printf("首次使用，暂无数据   （QAQ） \n");
        return;
    }
    while (fscanf(fp,"%s\t%s\t%s\n",contacts[count].name,contacts[count].gender,contacts[count].phone) == 3)
    {
        count++;
        if (count >= MAX) break;    
    }

    fclose(fp);
    if (count > 0)
    {
        printf("已加载 '%d' 名联系人\n",count);
    }
    
    
}



//保存退出部分
void SaveAndExit()
{
    FILE *fp = fopen("contacts.txt","w");
    if (fp == NULL)
    {
        printf("保存失败，请重试！！！\n");
        return;
    }

    for (int i = 0; i < count; i++)
    {
        fprintf(fp,"%s\t%s\t%s\n",contacts[i].name,contacts[i].gender,contacts[i].phone);
    }
    
    fclose(fp);
    printf("保存成功，现已保存 '%d' 名联系人\n",count);
    
}
