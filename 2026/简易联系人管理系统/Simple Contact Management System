#include <stdio.h>
#include <string.h>

#define MAX 100
#define NAME_LEN 50
#define PHONE_LEN 18
#define GENDER_LEN 20

struct Contacts
{
    char name[NAME_LEN];
    char phone[PHONE_LEN];
    char gender[GENDER_LEN];
   
};

struct Contacts contacts[MAX];
int count = 0;

void AddContact();
void ShowAllContacts();
void FindContacts();

void FilterContact();
void FilterByName();
void FilterByGrender();

void DeletContacts();
void DeletContactsByName();
void DeletContactsByPhone();

void LoadContacts();
void SaveAndExit();



